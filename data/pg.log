	        SUM(CASE WHEN s.ENC_STATE = 'Full' THEN 1 ELSE 0 END) AS full_encryption,
	        SUM(CASE WHEN s.ENC_STATE = 'Partial' THEN 1 ELSE 0 END) AS partial_encryption,
	        COUNT(*) AS total_profiles
	    FROM SecurityProfile s
	    GROUP BY s.RecordRegistry
	),
	country_metrics AS (
	    SELECT
	        cs.country_code,
	        COUNT(DISTINCT cs.RecordRegistry) AS profile_count,
	        AVG(cs.sensitivity_score) AS avg_sensitivity,
	        SUM(sc.full_encryption) AS full_encrypted_count,
	        SUM(sc.partial_encryption) AS partial_encrypted_count,
	        SUM(sc.total_profiles) AS total_protected_count
	    FROM country_sensitivity cs
	    JOIN security_coverage sc ON cs.RecordRegistry = sc.RecordRegistry
	    GROUP BY cs.country_code
	)
	SELECT
	    country_code AS country,
	    profile_count,
