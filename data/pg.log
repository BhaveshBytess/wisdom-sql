	                    WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'temperature') AS REAL) BETWEEN 10 AND 30 THEN 1
	                    ELSE 0
	                END +
	                CASE
	                    WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'humidity') AS REAL) BETWEEN 30 AND 70 THEN 1
	                    ELSE 0
	                END +
	                CASE
	                    WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'illumination') AS REAL) BETWEEN 500 AND 2000 THEN 1
	                    ELSE 0
	                END
	            ) = 1 THEN 'Medium'
	            ELSE 'Low'
	        END AS env_suitability_score,
	        AVG(
	            CASE
	                WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'temperature') AS REAL) BETWEEN 10 AND 30 THEN 1
	                ELSE 0
	            END +
	            CASE
	                WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'humidity') AS REAL) BETWEEN 30 AND 70 THEN 1
	                ELSE 0
	            END +
	            CASE
	                WHEN CAST(jsonb_extract_path_text(e.ambient_cond, 'illumination') AS REAL) BETWEEN 500 AND 2000 THEN 1
	                ELSE 0
	            END
	        ) * 100 AS env_score_value
	    FROM environment e
	    GROUP BY e.zoneref
	),
	quartiles AS (
	    SELECT
	        env_suitability_score,
	        env_score_value,
	        NTILE(4) OVER (ORDER BY env_score_value) AS quartile_rank
	    FROM env_scores
	)
	SELECT
	    s.zoneregistry AS location_code,
	    s.zonelabel AS location_name,
	    COALESCE(wa.avg_temp, 'N/A') AS avg_temperature,
	    COALESCE(wa.avg_humidity, 'N/A') AS avg_humidity,
	    COALESCE(wa.avg_illumination, 'N/A') AS avg_illumination,
	    es.env_suitability_score,
	    q.quartile_rank,
	    q.env_suitability_score AS env_condition_category
	FROM sites s
	LEFT JOIN weather_avg wa ON s.zoneregistry = wa.zoneref
	LEFT JOIN env_scores es ON s.zoneregistry = es.zoneref
	LEFT JOIN quartiles q ON es.zoneref = q.env_suitability_score AND es.env_score_value = q.env_score_value
	ORDER BY q.quartile_rank, s.zoneregistry
