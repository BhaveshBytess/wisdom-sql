	                     WHEN art.ageYears BETWEEN 300 AND 500 THEN 3
	                     ELSE 1
	                 END) >= 10 THEN 'Medium Priority'
	           ELSE 'Low Priority'
	       END AS priority_level
	FROM ArtifactsCore art
	LEFT JOIN ArtifactRatings rat ON art.ARTregID = rat.ART_link
	WHERE art.DYNASTY IN ('Ming', 'Qing')
	ORDER BY priority_score DESC
