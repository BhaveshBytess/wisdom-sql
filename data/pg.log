	      WHEN o.order_attributes->>'side' = 'buy' THEN 'Bullish'
	      WHEN o.order_attributes->>'side' = 'sell' THEN 'Bearish'
	      ELSE 'Neutral'
	    END AS flow_dominance,
	    CASE
	      WHEN SUM(CASE WHEN o.order_attributes->>'side' = 'buy' THEN 1 ELSE 0 END) > SUM(CASE WHEN o.order_attributes->>'side' = 'sell' THEN 1 ELSE 0 END) * 1.5 THEN 'High'
	      WHEN SUM(CASE WHEN o.order_attributes->>'side' = 'sell' THEN 1 ELSE 0 END) > SUM(CASE WHEN o.order_attributes->>'side' = 'buy' THEN 1 ELSE 0 END) * 1.5 THEN 'High'
	      WHEN SUM(CASE WHEN o.order_attributes->>'side' = 'buy' THEN 1 ELSE 0 END) > SUM(CASE WHEN o.order_attributes->>'side' = 'sell' THEN 1 ELSE 0 END) THEN 'Medium'
	      WHEN SUM(CASE WHEN o.order_attributes->>'side' = 'sell' THEN 1 ELSE 0 END) > SUM(CASE WHEN o.order_attributes->>'side' = 'buy' THEN 1 ELSE 0 END) THEN 'Medium'
	      ELSE 'Low'
	    END AS whale_activity
	  FROM orders o
	  WHERE o.order_attributes IS NOT NULL
	  GROUP BY o.exchSpot
	),
	price_changes AS (
	  SELECT
	    m.EXCH_SPOT AS market_pair,
	    AVG(EXTRACT(EPOCH FROM (m.TimeTrack - LAG(m.TimeTrack) OVER (PARTITION BY m.EXCH_SPOT ORDER BY m.TimeTrack)))) AS avg_time_diff_hours,
	    (LAG(m.orderbook_metrics->>'lastPrice') OVER (PARTITION BY m.EXCH_SPOT ORDER BY m.TimeTrack) - m.orderbook_metrics->>'lastPrice') /
	      NULLIF(LAG(m.orderbook_metrics->>'lastPrice') OVER (PARTITION BY m.EXCH_SPOT ORDER BY m.TimeTrack), 0) * 100 AS price_change_pct
	  FROM marketdata m
	  WHERE m.orderbook_metrics IS NOT NULL AND m.orderbook_metrics->>'lastPrice' IS NOT NULL
	),
	smart_money_success AS (
	  SELECT
	    s.market_pair,
	    s.flow_dominance,
	    s.whale_activity,
	    AVG(CASE WHEN p.price_change_pct > 0 AND s.flow_dominance = 'Bullish' THEN 1
	             WHEN p.price_change_pct < 0 AND s.flow_dominance = 'Bearish' THEN 1
	             ELSE 0
	        END) AS success_rate
	  FROM smart_money_flow s
	  JOIN price_changes p ON s.market_pair = p.market_pair
	  GROUP BY s.market_pair, s.flow_dominance, s.whale_activity
	)
	SELECT
	  flow_dominance AS "Dominance Category",
	  whale_activity AS "Whale-Driven Market Activity",
	  market_pair AS "Market Pair",
	  AVG(CASE WHEN avg_time_diff_hours <= 3600 THEN price_change_pct ELSE NULL END) AS "Avg 1h Price Change (%)",
	  AVG(CASE WHEN avg_time_diff_hours <= 14400 THEN price_change_pct ELSE NULL END) AS "Avg 4h Price Change (%)",
	  AVG(CASE WHEN avg_time_diff_hours <= 86400 THEN price_change_pct ELSE NULL END) AS "Avg 24h Price Change (%)",
	  ROUND(success_rate * 100, 2) AS "Smart Money Success Rate (%)"
	FROM (
	  SELECT
	    s.flow_dominance,
	    s.whale_activity,
	    s.market_pair,
	    p.price_change_pct,
	    p.avg_time_diff_hours
	  FROM smart_money_flow s
	  JOIN price_changes p ON s.market_pair = p.market_pair
	  JOIN smart_money_success smr ON s.market_pair = smr.market_pair AND s.flow_dominance = smr.flow_dominance AND s.whale_activity = smr.whale_activity
	) combined_data
	GROUP BY flow_dominance, whale_activity, market_pair, success_rate
	ORDER BY "Smart Money Success Rate (%)" DESC
