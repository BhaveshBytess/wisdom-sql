2026-07-15 00:07:22.886 IST [24116] HINT:  Perhaps you meant to reference the column "o.exchSpot".
2026-07-15 00:07:22.886 IST [24116] STATEMENT:  WITH smart_flow AS (
	  SELECT
	    o.exchSpot AS market_pair,
	    CASE
	      WHEN o.order_attributes->>'side' = 'buy' THEN 'Dominant_Buy'
	      WHEN o.order_attributes->>'side' = 'sell' THEN 'Dominant_Sell'
	      ELSE 'Dominance_Undetermined'
	    END AS flow_dominance,
	    CASE
	      WHEN o.order_attributes->>'side' = 'buy' THEN 'Whale_Driven_Market_Buy'
	      WHEN o.order_attributes->>'side' = 'sell' THEN 'Whale_Driven_Market_Sell'
	      ELSE 'Whale_Activity_Undetermined'
	    END AS whale_activity,
	    o.TimeCode,
	    md.TimeTrack,
	    m.priceShiftDay
	  FROM orders o
	  JOIN marketdata md ON o.exchSpot = md.EXCH_SPOT
	  JOIN marketstats m ON md.EXCH_SPOT = m.FundSpot::text AND md.TimeTrack BETWEEN m.FundSpot AND m.FundSpot + INTERVAL '1 day'
	  WHERE o.order_attributes->>'side' IN ('buy', 'sell')
	  AND md.TimeTrack >= CURRENT_TIMESTAMP - INTERVAL '30 days'
	),
	
	price_changes AS (
	  SELECT
	    market_pair,
	    flow_dominance,
	    whale_activity,
	    AVG(
	      CASE
	        WHEN EXTRACT(EPOCH FROM (TimeTrack - TimeCode)) <= 3600 THEN (priceShiftDay::real - 1.0) * 100
	        ELSE NULL
	      END
	    ) AS avg_price_change_1h,
	    AVG(
	      CASE
	        WHEN EXTRACT(EPOCH FROM (TimeCode - TimeTrack)) <= 14400 THEN (priceShiftDay::real - 1.0) * 100
	        ELSE NULL
	      END
	    ) AS avg_price_change_4h,
	    AVG(
	      CASE
	        WHEN EXTRACT(EPOCH FROM (TimeCode - TimeTrack)) <= 86400 THEN (priceShiftDay::real - 1.0) * 100
	        ELSE NULL
	      END
	    ) AS avg_price_change_24h
	  FROM smart_flow
	  GROUP BY market_pair, flow_dominance, whale_activity
	),
	
	success_rates AS (
	  SELECT
	    s.market_pair,
	    s.flow_dominance,
	    s.whale_activity,
	    COUNT(*) AS total_flows,
	    SUM(
	      CASE
	        WHEN
	          (s.flow_dominance = 'Dominant_Buy' AND s.priceShiftDay::real > 1.0) OR
	          (s.flow_dominance = 'Dominant_Sell' AND s.priceShiftDay::real < 1.0)
	        THEN 1
	        ELSE 0
	      END
	    ) AS successful_flows
	  FROM smart_flow s
	  GROUP BY s.market_pair, s.flow_dominance, s.whale_activity
	)
	
	SELECT
	  sr.market_pair,
	  sr.flow_dominance AS dominance_category,
	  sr.whale_activity,
	  pc.avg_price_change_1h,
	  pc.avg_price_change_4h,
	  pc.avg_price_change_24h,
	  ROUND(sr.successful_flows::real / NULLIF(sr.total_flows, 0) * 100, 2) AS success_rate_percentage,
	  sr.successful_flows,
	  sr.total_flows
	FROM success_rates sr
	JOIN price_changes pc ON sr.market_pair = pc.market_pair AND sr.flow_dominance = pc.flow_dominance AND sr.whale_activity = pc.whale_activity
