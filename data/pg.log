	             ELSE 0.5 END AS diagnosis_score,
	        CASE WHEN m.wait_time = 'Immediate' THEN 0.9
	             WHEN m.wait_time LIKE '%year%' THEN 0.1
	             ELSE 0.5 END AS urgency_score
	    FROM allocation_details a
	    JOIN recipients_demographics r ON a.recip_ref_reg = r.recip_registry
	    JOIN donors_demographics d ON a.donor_ref_reg = d.contrib_registry
	    LEFT JOIN clinical c ON r.recip_registry = c.clin_recip_registry
