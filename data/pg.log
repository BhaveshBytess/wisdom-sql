	        SUM(CASE WHEN resource_req->>'type' = 'water' THEN (resource_req->>'quantity')::real ELSE 0 END) AS total_water_required_per_day
	    FROM combined_events
	    GROUP BY event_id, event_time, hazard_type, location, latcoord, lon_coord, damaged_pop
	),
	inventory AS (
	    SELECT
	        SUM(hub_cap_tons * invaccpct / 100.0) AS total_food_stock,
	        SUM(store_cap_m3 * invaccpct / 100.0 * 1000.0) AS total_water_stock_liters,
