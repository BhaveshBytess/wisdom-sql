	      WHERE aq.env_link LIKE '%' || ac.ARTregID || '%'
	    ), 0) +
	    COALESCE((
	      SELECT SUM(
	        COALESCE(er.TEMPc - 20, 0) * 0.1 +
	        COALESCE(er.RH - 50, 0) * 0.15 +
	        COALESCE(er.tempVar24, 0) * 0.05 +
	        COALESCE(er.RHvar, 0) * 0.1
	      )
	      FROM EnvironmentalReadingsCore er
	      WHERE er.case_link IN (
	        SELECT mon_ID FROM Monitor_Showcase_Map WHERE case_ID = sc.caseID
	      )
	    ), 0) +
	    COALESCE((
	      SELECT SUM(
	        COALESCE(sp.vibra_mms2, 0) * 0.2 +
	        COALESCE(sp.noise_dB - 40, 0) * 0.05 +
	        COALESCE(sp.dust_Mg_m2, 0) * 0.25 +
	        COALESCE(sp.microbe_CFU / 1000, 0) * 0.25 +
	        COALESCE(sp.moldIdx, 0) * 0.25
	      )
	      FROM SurfaceAndPhysicalReadings sp
	      WHERE sp.env_link IN (
	        SELECT mon_ID FROM Monitor_Showcase_Map WHERE case_ID = sc.caseID
	      )
	    ), 0) AS total_threat_score
	  FROM ArtifactsCore ac
	  JOIN Showcases sc ON ac.ARTregID = sc.case_environment_profile->>'artifact_id'
	  JOIN RiskAssessments rr ON sc.caseID = rr.art_concern
	  WHERE rr.risk_level = 'Medium-High'
	)
	SELECT ARTregID, total_threat_score
	FROM environmental_threats
	ORDER BY total_threat_score DESC
	LIMIT 10
