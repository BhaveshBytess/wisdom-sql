	    CASE WHEN LAG(price, 1) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack) > price THEN LAG(price, 1) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack) - price ELSE 0 END AS loss
