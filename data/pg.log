	FROM (
	    SELECT
	        EXCH_SPOT,
	        TimeTrack,
	        CAST(md_ref->>'price' AS real) AS closing_price,
	        LAG(CAST(md_ref->>'price' AS real)) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack) AS prev_closing_price
	    FROM analyticsindicators JOIN marketdata ON analyticsindicators.md_ref = marketdata.md_link
	    WHERE TimeTrack >= NOW() - INTERVAL '14 days'
	) t
	GROUP BY EXCH_SPOT, TimeTrack
	), rsi_calc AS (
	SELECT
	    EXCH_SPOT,
	    TimeTrack,
	    100 - (100 / (1 + gain_avg / NULLIF(loss_avg, 0))) AS rsi_value
	FROM rsi
	),
	macd AS (
	SELECT
	    EXCH_SPOT,
	    TimeTrack,
	    md_ref->>'price' AS price,
	    AVG(CAST(md_ref->>'price' AS real)) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 11 PRECEDING AND CURRENT ROW) -
	    AVG(CAST(md_ref->>'price' AS real)) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 25 PRECEDING AND 12 PRECEDING) AS macd_line
	FROM analyticsindicators JOIN marketdata ON analyticsindicators.md_ref = marketdata.md_link
	),
	bbands AS (
	SELECT
	    EXCH_SPOT,
	    TimeTrack,
	    STDDEV(CAST(md_ref->>'price' AS real)) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 19 PRECEDING AND CURRENT ROW) * 2 AS bb_width
	FROM analyticsindicators JOIN marketdata ON analyticsindicators.md_ref = marketdata.md_link
	),
	tech_meter AS (
	SELECT
	    EXCH_SPOT,
	    TimeTrack,
	    CASE
	        WHEN r.rsi_value > 70 AND m.macd_line < 0 THEN 'Strong Sell'
	        WHEN r.rsi_value < 30 AND m.macd_line > 0 THEN 'Strong Buy'
	        WHEN r.rsi_value > 50 AND m.macd_line > 0 THEN 'Buy'
	        WHEN r.rsi_value < 50 AND m.macd_line < 0 THEN 'Sell'
	        WHEN b.bb_width < AVG(b.bb_width) OVER (PARTITION BY b.EXCH_SPOT) * 0.8 THEN 'Volatile'
	        ELSE 'Neutral'
	    END AS signal_direction,
	    (r.rsi_value * 0.3 + CASE WHEN m.macd_line > 0 THEN 1 ELSE -1 END * 50 + CASE WHEN b.bb_width > AVG(b.bb_width) OVER (PARTITION BY b.EXCH_SPOT) THEN 20 ELSE 0 END) AS strength_score
	FROM marketdata m JOIN rsi_calc r ON m.EXCH_SPOT = r.EXCH_SPOT AND m.TimeTrack = r.TimeTrack
