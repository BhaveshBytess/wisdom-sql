	    TimeTrack,
	    price,
	    sma_14,
	    stdev_14,
	    100 - (100 / (1 + (avg_gain / NULLIF(avg_loss, 0)))) AS rsi_14,
	    avg_gain / NULLIF(avg_loss, 0) AS rs
	  FROM rsi_final
	  WHERE avg_loss != 0
	),
	macd_calc AS (
	  SELECT
	    EXCH_SPOT,
	    TimeTrack,
	    price,
	    sma_14,
	    stdev_14,
	    AVG(price) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 25 PRECEDING AND CURRENT ROW) AS ema_26,
	    AVG(price) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 11 PRECEDING AND CURRENT ROW) AS ema_12,
	    ema_12 - ema_26 AS macd_line,
	    AVG(ema_12 - ema_26) OVER (PARTITION BY EXCH_SPOT ORDER BY TimeTrack ROWS BETWEEN 8 PRECEDING AND CURRENT ROW) AS signal_line
