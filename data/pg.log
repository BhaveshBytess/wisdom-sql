	            WHEN art.DYNASTY = 'Qing' THEN 2
	            ELSE 1
	        END as dynasty_weight
	    FROM ArtifactsCore art
	    WHERE art.DYNASTY IN ('Ming', 'Qing')
	),
	PriorityFactors AS (
	    SELECT
	        ma.artifact_id,
	        ma.title,
	        ma.dynasty,
	        ma.dynasty_weight,
