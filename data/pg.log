	        WHEN (dynasty_weight * 0.3 + conserve_factor * 0.25 + cleanliness_factor * 0.2 + risk_factor * 0.15 + exposure_count * 0.1) >= 3.0 THEN 'Medium'
	        ELSE 'Low'
	    END AS priority_level
	FROM PriorityFactors
	ORDER BY priority_score DESC
