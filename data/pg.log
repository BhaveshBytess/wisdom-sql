	    (content_metrics->>'$.posts')::real AS post_activity,
	    (content_metrics->>'$.likes')::real AS like_activity,
	    (content_metrics->>'$.shares')::real AS share_activity,
	    (content_metrics->>'$.comments')::real AS comment_activity
	  FROM content_activity
	  WHERE content_metrics->>'$.timestamp' IS NOT NULL
	),
	usual_activity AS (
	  SELECT
	    acct_ref,
	    AVG(post_activity) AS avg_posts,
	    AVG(like_activity) AS avg_likes,
	    AVG(share_activity) AS avg_shares,
	    AVG(comment_activity) AS avg_comments
	  FROM hourly_activity
