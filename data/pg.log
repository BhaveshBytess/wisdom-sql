2026-07-15 00:05:26.373 IST [26680] STATEMENT:  WITH job_applications AS (
	    SELECT
	        c.filekey,
	        c.soctitle,
	        COUNT(DISTINCT c.filekey) AS app_count
	    FROM
	        cases c
	    GROUP BY
	        c.filekey, c.soctitle
	    HAVING
	        COUNT(DISTINCT c.filekey) >= 30
	),
	pay_comparison AS (
	    SELECT
	        c.filekey,
	        c.soctitle,
	        CASE
	            WHEN c.fulltimeind = 'Y' AND pw.wage_details->>'payper' = 'Year'
	                THEN ROUND(
	                    ((CAST(c.headct AS REAL) * 2080 * CAST(pw.wage_details->>'wage_lvl1' AS REAL)) -
	                     (CAST(pw.wage_details->>'wage_lvl1' AS REAL) * CAST(c.headct AS REAL))) /
	                    (CAST(pw.wage_details->>'wage_lvl1' AS REAL) * CAST(c.headct AS REAL)) * 100, 2)
	            WHEN c.fulltimeind = 'N' AND pw.wage_details->>'payper' = 'Hour'
	                THEN ROUND(
	                    ((CAST(c.headct AS REAL) * CAST(pw.wage_details->>'wage_lvl1' AS REAL)) -
	                     (CAST(pw.wage_details->>'wage_lvl1' AS REAL) * CAST(c.headct AS REAL))) /
	                    (CAST(pw.wage_details->>'wage_lvl1' AS REAL) * CAST(c.headct AS REAL)) * 100, 2)
	            ELSE NULL
	        END AS pct_diff
	    FROM
	        cases c
	    JOIN
	        prevailing_wage pw ON c.agreelc = pw.trackno
	    WHERE
	        pw.wage_details->>'payper' IN ('Year', 'Hour')
	        AND c.fulltimeind IN ('Y', 'N')
	),
	filtered_pay AS (
	    SELECT
	        filekey,
	        soctitle,
	        pct_diff
	    FROM
	        pay_comparison
	    WHERE
	        pct_diff IS NOT NULL
	        AND pct_diff > 10
	)
	SELECT
	    fp.soctitle AS job_title,
	    ja.app_count AS num_applications,
	    fp.pct_diff AS avg_pay_difference,
	    CASE WHEN c.visacls = 'H-1B' THEN 'Skill Shortage Occupation' ELSE NULL END AS occupation_flag
	FROM
	    filtered_pay fp
	JOIN
	    job_applications ja ON fp.filekey = ja.filekey
	JOIN
	    cases c ON fp.filekey = c.filekey
	ORDER BY
	    fp.pct_diff DESC
	LIMIT 5
