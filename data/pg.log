2026-07-15 00:05:26.371 IST [26680] STATEMENT:  WITH job_counts AS (
	  SELECT
	    c.filekey,
	    COUNT(*) AS application_count
	  FROM cases c
	  GROUP BY c.filekey
	  HAVING COUNT(*) >= 30
	),
	pay_comparison AS (
	  SELECT
	    c.filekey,
	    c.soccd,
	    c.soctitle,
	    c.headct,
	    c.newemp,
	    c.contemp,
	    c.changeprev,
	    c.siteslots,
	    c.statbasis,
	    c.agreelc,
	    CASE
	      WHEN pw.wage_details->>'pw_unit' = 'Year'
	           AND EXISTS (
	             SELECT 1 FROM case_worksite cws
	             WHERE cws.dockkey = c.filekey
	             AND cws.wagetrack = pw.trackno
	           )
	      THEN (pw.wage_details->>'pw_amount')::numeric
	      ELSE NULL
	    END AS prevailing_yearly_wage,
	    CASE
	      WHEN pw.wage_details->>'pw_unit' = 'Hour'
	           AND EXISTS (
	             SELECT 1 FROM case_worksite cws
	             WHERE cws.dockkey = c.filekey
	             AND cws.wagetrack = pw.trackno
	           )
	      THEN (pw.wage_details->>'pw_amount')::numeric * 2080
	      ELSE NULL
	    END AS prevailing_yearly_wage_hourly_converted
	  FROM cases c
	  LEFT JOIN prevailing_wage pw ON pw.trackno = c.headct
	  WHERE c.headct IS NOT NULL
	),
	combined_pay AS (
	  SELECT
	    pc.filekey,
	    pc.soccd,
	    pc.soctitle,
	    jc.application_count,
	    pc.prevailing_yearly_wage,
	    pc.prevailing_yearly_wage_hourly_converted,
	    CASE
	      WHEN pc.prevailing_yearly_wage IS NOT NULL
	      THEN (pc.prevailing_yearly_wage) / NULLIF(pc.headct, 0)
	      WHEN pc.prevailing_yearly_wage_hourly_converted IS NOT NULL
	      THEN (pc.prevailing_yearly_wage_hourly_converted) / NULLIF(pc.headct, 0)
	      ELSE NULL
	    END AS prevailing_wage_per_worker
	  FROM pay_comparison pc
	  JOIN job_counts jc ON jc.filekey = pc.filekey
	),
	cases_detail AS (
	  SELECT
	    c.filekey,
	    c.soctitle,
	    c.soccd,
	    jc.application_count,
	    cp.prevailing_wage_per_worker,
	    (c.headct::numeric) AS prevailing_wage
	  FROM cases c
	  JOIN job_counts jc ON jc.filekey = c.filekey
	  JOIN combined_pay cp ON cp.filekey = c.filekey
	)
	SELECT
	  cd.soctitle AS title,
	  cd.application_count AS "number of applications",
	  ROUND(
	    ((cd.prevailing_wage - cd.prevailing_wage_per_worker) / cd.prevailing_wage_per_worker * 100)::numeric,
	    2
	  ) AS "average percentage pay difference",
	  CASE
	    WHEN cd.soccd IN (
	      SELECT jsonb_array_elements_text(attorney.attorney_profile->'soc_shortage_list')
	      FROM attorney
	      WHERE attorney.lawmail IN (
	        SELECT DISTINCT counselmail
	        FROM case_attorney
	        WHERE counselfor = 'Employer'
	      )
	      LIMIT 1
	    ) THEN 'Skill Shortage Occupation'
	    ELSE NULL
	  END AS "Skill Shortage Occupation"
	FROM cases_detail cd
	WHERE cd.prevailing_wage_per_worker IS NOT NULL
	  AND cd.prevailing_wage IS NOT NULL
	  AND cd.prevailing_wage > 0
	  AND (cd.prevailing_wage - cd.prevailing_wage_per_worker) > (cd.prevailing_wage_per_worker * 0.10)
	ORDER BY
	  (((cd.prevailing_wage - cd.prevailing_wage_per_worker) / cd.prevailing_wage_per_worker * 100)::numeric) DESC
	LIMIT 5
