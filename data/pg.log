	            WHEN h.hla_mis_count > 50 THEN 'High HLA mismatch'
	            WHEN c.diag_detail LIKE '%CKD%' THEN 'Severe kidney diagnosis'
	            ELSE 'Other marginal criteria'
	        END AS marginal_reason,
	        r.age_count AS patient_age,
	        d.age_count AS donor_age,
	        1.0 / (1.0 + ABS(d.age_count - r.age_count)) AS age_score,
	        CASE WHEN h.hla_mis_count > 50 THEN 0.1
	             WHEN h.hla_mis_count > 30 THEN 0.3
	             ELSE 0.5 END AS hla_score,
	        CASE WHEN c.diag_detail LIKE '%CKD%' THEN 0.2
