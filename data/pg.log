	    ha.acct_ref,
	    ha.hour,
	    (ha.post_activity - ua.avg_posts)::real AS post_diff,
	    (ha.like_activity - ua.avg_likes)::real AS like_diff,
	    (ha.share_activity - ua.avg_shares)::real AS share_diff,
	    (ha.comment_activity - ua.avg_comments)::real AS comment_diff,
	    SQRT(
