	    COALESCE(ca.content_metrics->>'exposure_score', 0) +
	    COALESCE(im.ConvNat * 2, 0) +
	    COALESCE(nm.EngAuth * 3, 0) +
	    COALESCE(r.risk_profile->>'exposure_score', 0) AS overall_exposure
	  FROM accounts a
	  LEFT JOIN cluster_analysis c ON a.acct_ref = c.CLSTR_PIN
	  LEFT JOIN behavioral_scores bs ON a.acct_ref = bs.acct_beh
	  LEFT JOIN content_activity ca ON a.acct_ref = ca.acct_slot
	  LEFT JOIN interaction_metrics im ON a.acct_ref = im.acct_dm
	  LEFT JOIN network_metrics nm ON a.acct_ref = nm.acct_node
	  LEFT JOIN risk_and_moderation r ON a.acct_ref = r.acct_risk
	  WHERE a.acct_form IS NOT NULL
	    AND a.StateFlag IS NOT NULL
	    AND a.ProfileScore IS NOT NULL
	)
	SELECT user_id, ROUND(overall_exposure, 3) AS overall_exposure
	FROM exposure_metrics
	WHERE overall_exposure > 0
	ORDER BY overall_exposure DESC
	LIMIT 20
