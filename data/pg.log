	  SELECT
	    c.jobtag,
	    COUNT(*) AS application_count
	  FROM cases c
	  GROUP BY c.jobtag
	  HAVING COUNT(*) >= 30
	),
	pay_comparison AS (
	  SELECT
	    c.jobtag,
	    CASE
	      WHEN c.fulltimeind = 'Y' AND c.headct > 0 THEN w.wage_details ->> '$.wage_rate_of_pay_from'
	      ELSE NULL
	    END AS offered_pay,
	    CASE
	      WHEN w.trackno IS NOT NULL THEN pw.wage_details ->> '$.wage_rate_of_pay_from'
	      ELSE NULL
	    END AS market_pay,
	    CASE
	      WHEN c.fulltimeind = 'Y' AND c.headct > 0 AND w.wage_details ->> '$.wage_unit_of_pay' = pw.wage_details ->> '$.wage_unit_of_pay'
	      THEN (CAST(c.headct * (w.wage_details ->> '$.wage_rate_of_pay_from') AS REAL) / CAST(pw.wage_details ->> '$.wage_rate_of_pay_from' AS REAL) - 1) * 100
	      ELSE NULL
	    END AS pay_difference_pct
	  FROM cases c
	  JOIN case_worksite w ON c.filekey = w.dockkey
	  JOIN prevailing_wage pw ON w.wagetrack = pw.trackno
	  WHERE w.wagetrack IS NOT NULL
	    AND c.headct > 0
	    AND pw.wage_details ->> '$.wage_rate_of_pay_from' IS NOT NULL
	    AND w.wage_details ->> '$.wage_rate_of_pay_from' IS NOT NULL
	    AND w.wage_details ->> '$.wage_unit_of_pay' IS NOT NULL
	    AND pw.wage_details ->> '$.wage_unit_of_pay' IS NOT NULL
	)
	SELECT
	  c.jobtag AS title,
	  ja.application_count AS "number of applications",
	  ROUND(AVG(pc.pay_difference_pct), 2) AS "average percentage pay difference",
	  CASE WHEN c.visacls = 'S' THEN 'Skill Shortage Occupation' ELSE '' END AS "Skill Shortage Occupation"
	FROM cases c
	JOIN job_applications ja ON c.jobtag = ja.jobtag
	JOIN pay_comparison pc ON c.jobtag = pc.jobtag
	WHERE pc.offered_pay > pc.market_pay * 1.1
	GROUP BY c.jobtag, ja.application_count, c.visacls
	ORDER BY AVG(pc.pay_difference_pct) DESC
	LIMIT 5
