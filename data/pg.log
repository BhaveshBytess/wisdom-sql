	        WHEN s.env_handling_sensitivity->>'vulnerability' = 'Medium' THEN 'Medium'
	        WHEN s.env_handling_sensitivity->>'vulnerability' = 'Low' THEN 'Low'
	        ELSE 'Unknown'
	    END
	ORDER BY
