	      WHEN a.StateFlag = 'Active' THEN 0.9
	      WHEN a.StateFlag = 'Suspended' THEN 0.5
	      WHEN a.StateFlag = 'Deleted' THEN 0.1
	      ELSE 0.0
	    END +
	    CASE WHEN a.VerifyMark = 'Verified' THEN 0.1 ELSE 0.0 END +
	    CASE WHEN a.acct_form = 'Business' THEN -0.05 ELSE 0.0 END +
	    CASE WHEN a.AGE_D > 365 THEN 0.2 ELSE 0.1 END +
	    COALESCE((SELECT MAX(real_value)
	              FROM behavioral_scores bs,
	              jsonb_array_elements(bs.behavioral_anomaly_scores) AS real_value
	              WHERE bs.acct_beh = a.acct_ref AND real_value IS NOT NULL), 0.0) * -0.1 +
	    COALESCE((SELECT MAX(ConfScore)
	              FROM monitoring m
	              WHERE m.acct_mon = a.acct_ref), 0.0) * 0.1 +
	    COALESCE((SELECT MAX(real_value)
	              FROM network_metrics nm,
	              jsonb_each_text(nm.ConnGrowPtn) AS real_value
	              WHERE nm.acct_node = a.acct_ref AND real_value IN ('Growth', 'Stable')), 1) * 0.05 +
	    COALESCE((SELECT MAX(real_value)
	              FROM interaction_metrics im,
	              jsonb_each_text(im.RespTimePtn) AS real_value
	              WHERE im.acct_dm = a.acct_ref AND real_value = 'Responsive'), 1) * 0.05 +
	    COALESCE((SELECT MAX(TxtUniq)
	              FROM interaction_metrics im
	              WHERE im.acct_dm = a.acct_ref), 0.0) * 0.1 +
	    COALESCE((SELECT MAX(real_value)
	              FROM profiles p,
	              jsonb_each_text(p.BioKwHit) AS real_value
	              WHERE p.acct_anchor = a.acct_ref AND real_value = 'Professional'), 1) * 0.05 +
	    CASE WHEN EXISTS (
	      SELECT 1 FROM account_clusters ac
	      JOIN cluster_analysis ca ON ac.clu_ref = ca.CLSTR_PIN
	      WHERE ca.CluRole = 'Trusted'
	      AND ac.acct_bridge = a.acct_ref
	    ) THEN 0.1 ELSE 0.0 END AS stability_score
	  FROM accounts a
	)
	SELECT acct_ref AS account, ROUND(stability_score, 3) AS reputation_stability
	FROM score_calculations
	ORDER BY stability_score DESC
	LIMIT 1
