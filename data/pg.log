	  unique_fans AS "Unique Fans Who Sent Gifts",
	  gift_transactions AS "Number of Gift Transactions"
	FROM gift_spending
	ORDER BY
	  idol_genre,
	  fan_language,
	  marketing_opt_in;
	
	WITH genre_totals AS (
	  SELECT
	    COALESCE(demo_profile->>'genre', 'Unknown') AS idol_genre,
	    SUM(
	      COALESCE(
	        (gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE gift_metrics IS NOT NULL
	    AND (gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY COALESCE(demo_profile->>'genre', 'Unknown')
	),
	language_totals AS (
	  SELECT
	    COALESCE(lang_pref, 'Unknown') AS fan_language,
	    SUM(
	      COALESCE(
	        (gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE gift_metrics IS NOT NULL
	    AND (gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY COALESCE(lang_pref, 'Unknown')
	),
	marketing_totals AS (
	  SELECT
	    CASE WHEN status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END AS marketing_opt_in,
	    SUM(
	      COALESCE(
	        (gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE gift_metrics IS NOT NULL
	    AND (gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY CASE WHEN status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END
	),
	genre_language_totals AS (
	  SELECT
	    COALESCE(f.demo_profile->>'genre', 'Unknown') AS idol_genre,
	    COALESCE(f.lang_pref, 'Unknown') AS fan_language,
	    SUM(
	      COALESCE(
	        (i.gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT i.interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT i.interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE i.gift_metrics IS NOT NULL
	    AND (i.gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY
	    COALESCE(f.demo_profile->>'genre', 'Unknown'),
	    COALESCE(f.lang_pref, 'Unknown')
	),
	genre_marketing_totals AS (
	  SELECT
	    COALESCE(f.demo_profile->>'genre', 'Unknown') AS idol_genre,
	    CASE WHEN f.status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END AS marketing_opt_in,
	    SUM(
	      COALESCE(
	        (i.gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT i.interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT i.interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE i.gift_metrics IS NOT NULL
	    AND (i.gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY
	    COALESCE(f.demo_profile->>'genre', 'Unknown'),
	    CASE WHEN f.status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END
	),
	language_marketing_totals AS (
	  SELECT
	    COALESCE(f.lang_pref, 'Unknown') AS fan_language,
	    CASE WHEN f.status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END AS marketing_opt_in,
	    SUM(
	      COALESCE(
	        (i.gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT i.interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT i.interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions i
	  JOIN fans f ON i.interact_fan_pivot = f.user_registry
	  WHERE i.gift_metrics IS NOT NULL
	    AND (i.gift_metrics->>'total_spent_usd') IS NOT NULL
	  GROUP BY
	    COALESCE(f.lang_pref, 'Unknown'),
	    CASE WHEN f.status_tag LIKE '%marketing%' THEN 'Opted In' ELSE 'Opted Out' END
	),
	grand_total AS (
	  SELECT
	    'Grand Total' AS category,
	    SUM(
	      COALESCE(
	        (gift_metrics->>'total_spent_usd')::real,
	        0
	      )
	    ) AS total_gift_spent_usd,
	    COUNT(DISTINCT interact_idol_pivot) AS unique_idols,
	    COUNT(DISTINCT interact_fan_pivot) AS unique_fans,
	    COUNT(*) AS gift_transactions
	  FROM interactions
	  WHERE gift_metrics IS NOT NULL
	    AND (gift_metrics->>'total_spent_usd') IS NOT NULL
	)
	SELECT
	  'Breakdown by Idol Genre, Language, and Marketing Opt-In' AS report_section,
	  idol_genre AS "Dimension 1",
	  fan_language AS "Dimension 2",
	  marketing_opt_in AS "Dimension 3",
	  total_gift_spent_usd AS "Total Gift Spending (USD)",
	  unique_idols AS "Unique Idols Received Gifts",
	  unique_fans AS "Unique Fans Who Sent Gifts",
	  gift_transactions AS "Number of Gift Transactions"
	FROM gift_spending
	UNION ALL
	SELECT
	  'Breakdown by Idol Genre Only' AS report_section,
	  idol_genre AS "Dimension 1",
	  NULL AS "Dimension 2",
	  NULL AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM genre_totals
	UNION ALL
	SELECT
	  'Breakdown by Language Only' AS report_section,
	  fan_language AS "Dimension 1",
	  NULL AS "Dimension 2",
	  NULL AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM language_totals
	UNION ALL
	SELECT
	  'Breakdown by Marketing Opt-In Only' AS report_section,
	  marketing_opt_in AS "Dimension 1",
	  NULL AS "Dimension 2",
	  NULL AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM marketing_totals
	UNION ALL
	SELECT
	  'Breakdown by Idol Genre and Language' AS report_section,
	  idol_genre AS "Dimension 1",
	  fan_language AS "Dimension 2",
	  NULL AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM genre_language_totals
	UNION ALL
	SELECT
	  'Breakdown by Idol Genre and Marketing Opt-In' AS report_section,
	  idol_genre AS "Dimension 1",
	  NULL AS "Dimension 2",
	  marketing_opt_in AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM genre_marketing_totals
	UNION ALL
	SELECT
	  'Breakdown by Language and Marketing Opt-In' AS report_section,
	  fan_language AS "Dimension 1",
	  NULL AS "Dimension 2",
	  marketing_opt_in AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM language_marketing_totals
	UNION ALL
	SELECT
	  report_section,
	  category AS "Dimension 1",
	  NULL AS "Dimension 2",
	  NULL AS "Dimension 3",
	  total_gift_spent_usd,
	  unique_idols,
	  unique_fans,
	  gift_transactions
	FROM grand_total
	ORDER BY
	  report_section,
	  "Dimension 1",
	  "Dimension 2",
	  "Dimension 3"
