	  di.region_tag,
	  di.event_date,
	  cs.total_food_capacity,
	  cs.total_water_capacity,
	  cs.total_water_available,
	  -- Calculate days supply remaining for food
	  ROUND(cs.total_food_capacity / NULLIF(SUM(CASE WHEN ea.health_environment_profile->>'needs' = 'food' THEN 1 ELSE 0 END), 0), 2) AS food_supply_days,
	  -- Calculate days supply remaining for water (in liters)
