	        CASE
	            WHEN art.conserve_status = 'Critical' THEN 5
	            WHEN art.conserve_status = 'Poor' THEN 4
	            WHEN art.conserve_status = 'Fair' THEN 3
	            WHEN art.conserve_status = 'Good' THEN 2
	            ELSE 1
	        END AS conserve_factor,
	        -- Time since last cleaning factor (higher for longer periods)
	        CASE
	            WHEN maint.lastClean IS NULL THEN 5
	            WHEN maint.lastClean < CURRENT_DATE - INTERVAL '5 years' THEN 5
	            WHEN maint.lastClean < CURRENT_DATE - INTERVAL '3 years' THEN 4
	            WHEN maint.lastClean < CURRENT_DATE - INTERVAL '1 year' THEN 3
	            WHEN maint.lastClean < CURRENT_DATE - INTERVAL '6 months' THEN 2
	            ELSE 1
	        END AS cleanliness_factor,
	        -- Risk assessment factor (higher for higher risk)
	        COALESCE(CAST(risk.risk_level AS INTEGER), 0) AS risk_factor,
	        -- Exhibition exposure factor (higher for more frequent display)
	        (SELECT COUNT(*) FROM Monitor_Showcase_Map msm WHERE msm.case_ID = ma.artifact_id) AS exposure_count
