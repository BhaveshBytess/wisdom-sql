	        dh.hubregistry
	    FROM distributionhubs dh
	    GROUP BY dh.hubregistry
	),
	
	current_consumption AS (
	    SELECT
	        MAX(ba.needs_assess_status) AS needs_status,
	        MAX(ba.bene_feedbackscore) AS feedback_score
	    FROM beneficiariesandassessments ba
	    GROUP BY ba.bene_dist_ref
	)
	
	SELECT
	    ed.distregistry AS event_id,
	    ed.timemark AS event_date,
	    ed.haztype AS hazard_type,
	    ed.affectedarea AS location,
	    ed.region_tag AS region,
	    ed.latcoord AS latitude,
	    ed.lon_coord AS longitude,
	    ROUND(
	        CASE
	            WHEN cc.needs_status = 'Critical' THEN 1.0
	            WHEN cc.needs_status = 'High' THEN 0.8
	            WHEN cc.needs_status = 'Medium' THEN 0.6
	            WHEN cc.needs_status = 'Low' THEN 0.4
	            ELSE 0.5
	        END * sc.max_food_storage / NULLIF(MAX(f.fin_ops_ref::real), 0),
	        2
	    ) AS days_food_supply,
	    ROUND(
	        CASE
	            WHEN cc.feedback_score >= 75 THEN 0.2
	            WHEN cc.feedback_score >= 50 THEN 0.4
	            WHEN cc.feedback_score >= 25 THEN 0.6
	            ELSE 0.8
	        END * sc.max_water_storage / NULLIF(MAX(f.findistref::real), 0),
	        2
	    ) AS days_water_supply,
	    ROUND(
	        MAX(CASE WHEN ba.needs_assess_status = 'Critical' THEN ba.bene_feedbackscore * 100 ELSE 0 END) -
	        (sc.max_food_storage * 1000 / NULLIF(MAX(ba.bene_feedbackscore), 0)),
	        2
	    ) AS shelter_shortfall
	FROM event_details ed
	CROSS JOIN supply_calculation sc
	LEFT JOIN coordinationandevaluation ce ON ce.coord_dist_ref = ed.region_tag
	LEFT JOIN financials f ON f.findistref = ed.region_tag
	LEFT JOIN beneficiariesandassessments ba ON ba.bene_dist_ref = ed.region_tag
	LEFT JOIN current_consumption cc ON cc.hubregistry = sc.hubregistry
	GROUP BY ed.distregistry, ed.timemark, ed.haztype, ed.affectedarea, ed.region_tag, ed.latcoord, ed.lon_coord, sc.max_food_storage, sc.max_water_storage, sc.hubregistry, cc.needs_status, cc.feedback_score
