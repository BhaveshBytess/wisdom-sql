	    CASE
	        WHEN investigation_intensity = 'high' THEN 3
	        WHEN investigation_intensity = 'medium' THEN 2
	        WHEN investigation_intensity = 'low' THEN 1
	        ELSE 0
	    END AS investigation_intensity_score
	FROM intensity_scores
	ORDER BY investigation_intensity_score DESC, REC_COMP
	LIMIT 100
