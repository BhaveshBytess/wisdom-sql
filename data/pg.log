2026-07-15 00:07:22.888 IST [24116] STATEMENT:  WITH smart_money_flows AS (
	    SELECT
	        om.EXCH_SPOT AS market_pair,
	        CASE
	            WHEN om.order_attributes->>'$.flow_dominance' = 'Smart Money Buy Dominance' THEN 'Smart Money Buy'
	            WHEN om.order_attributes->>'$.flow_dominance' = 'Smart Money Sell Dominance' THEN 'Smart Money Sell'
	            WHEN om.order_attributes->>'$.flow_dominance' = 'Whale Buy Dominance' THEN 'Whale Buy'
	            WHEN om.order_attributes->>'$.flow_dominance' = 'Whale Sell Dominance' THEN 'Whale Sell'
	            ELSE 'Neutral'
	        END AS flow_dominance,
	        CASE
	            WHEN om.order_attributes->>'$.whale_activity' = 'High' THEN 'High'
	            WHEN om.order_attributes->>'$.whale_activity' = 'Medium' THEN 'Medium'
	            WHEN om.order_attributes->>'$.whale_activity' = 'Low' THEN 'Low'
	            ELSE 'Unknown'
	        END AS whale_activity,
	        md.EXCH_SPOT,
	        md.TimeTrack AS time_stamp,
	        md.orderbook_metrics->>'$.price_last' AS current_price
	    FROM orders om
	    JOIN marketdata md ON om.exchSpot = md.EXCH_SPOT
	    WHERE om.order_attributes->>'$.flow_dominance' IN (
	        'Smart Money Buy Dominance', 'Smart Money Sell Dominance',
	        'Whale Buy Dominance', 'Whale Sell Dominance'
	    )
	),
	
	price_changes AS (
	    SELECT
	        s.flow_dominance,
	        s.whale_activity,
	        s.market_pair,
	        s.time_stamp,
	        s.current_price,
	        LAG(s.current_price, 1) OVER (PARTITION BY s.market_pair ORDER BY s.time_stamp) AS prev_price_1h,
	        LAG(s.current_price, 4) OVER (PARTITION BY s.market_pair ORDER BY s.time_stamp) AS prev_price_4h,
	        LAG(s.current_price, 24) OVER (PARTITION BY s.market_pair ORDER BY s.time_stamp) AS prev_price_24h
	    FROM smart_money_flows s
	),
	
	calculations AS (
	    SELECT
	        flow_dominance,
	        whale_activity,
	        market_pair,
	        AVG(CASE WHEN prev_price_1h IS NOT NULL THEN (CAST(current_price AS REAL) - CAST(prev_price_1h AS REAL)) / CAST(prev_price_1h AS REAL) * 100 ELSE NULL END) AS avg_price_change_1h,
	        AVG(CASE WHEN prev_price_4h IS NOT NULL THEN (CAST(current_price AS REAL) - CAST(prev_price_4h AS REAL)) / CAST(prev_price_4h AS REAL) * 100 ELSE NULL END) AS avg_price_change_4h,
	        AVG(CASE WHEN prev_price_24h IS NOT NULL THEN (CAST(current_price AS REAL) - CAST(prev_price_24h AS REAL)) / CAST(prev_price_24h AS REAL) * 100 ELSE NULL END) AS avg_price_change_24h,
	        COUNT(*) AS total_records,
	        SUM(CASE
	            WHEN (flow_dominance LIKE '%Buy%' AND CAST(current_price AS REAL) > CAST(prev_price_1h AS REAL)) OR
	                 (flow_dominance LIKE '%Sell%' AND CAST(current_price AS REAL) < CAST(prev_price_1h AS REAL))
	            THEN 1 ELSE 0
	        END) AS successful_predictions_1h
	    FROM price_changes
	    GROUP BY flow_dominance, whale_activity, market_pair
	)
	
	SELECT
	    flow_dominance AS "Dominance Category",
	    whale_activity AS "Whale Activity Level",
	    market_pair AS "Market Pair",
	    ROUND(avg_price_change_1h, 4) AS "Avg Price Change (1h) %",
	    ROUND(avg_price_change_4h, 4) AS "Avg Price Change (4h) %",
	    ROUND(avg_price_change_24h, 4) AS "Avg Price Change (24h) %",
	    ROUND(COALESCE(successful_predictions_1h * 100.0 / total_records, 0), 2) AS "Smart Money Flow Success Rate %"
	FROM calculations
	ORDER BY "Smart Money Flow Success Rate %" DESC
