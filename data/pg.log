	                CASE
	                    WHEN m.mesh_specs->>'fidelity' = 'high' THEN 1.0
	                    ELSE 0.0
	                END
	            ) * 100.0 / NULLIF(COUNT(m.facetregistry), 0),
	            2
	        ) AS fidelity_proportion_percent
	    FROM sites z
	    LEFT JOIN mesh m ON z.zoneregistry = m.zoneref
	    GROUP BY z.zoneregistry, z.zonelabel
	),
	complexity AS (
	    SELECT
	        m.zoneref,
	        AVG(
	            CASE
	                WHEN m.mesh_specs->>'vertices' IS NOT NULL AND m.mesh_specs->>'vertices' != '0'
	                THEN CAST(m.mesh_specs->>'vertices' AS REAL) /
	                     NULLIF(CAST(m.mesh_specs->>'faces' AS REAL), 0)
	                ELSE 0
	            END
	        ) AS avg_mesh_complexity
	    FROM mesh m
	    GROUP BY m.zoneref
	),
	resolution AS (
	    SELECT
	        m.zoneref,
	        AVG(
	            CASE
	                WHEN m.mesh_specs->>'resolution_mm' IS NOT NULL
	                THEN CAST(m.mesh_specs->>'resolution_mm' AS REAL)
	                ELSE NULL
	            END
	        ) AS avg_resolution_mm
	    FROM mesh m
	    GROUP BY m.zoneref
	),
	accuracy AS (
	    SELECT
	        m.zoneref,
	        AVG(
	            CASE
	                WHEN m.mesh_specs->>'geometric_accuracy_mm' IS NOT NULL
	                THEN CAST(m.mesh_specs->>'geometric_accuracy_mm' AS REAL)
	                ELSE NULL
	            END
	        ) AS avg_geometric_accuracy_mm
	    FROM mesh m
	    GROUP BY m.zoneref
	)
	SELECT
	    mc.site_id,
	    mc.site_name,
	    mc.total_mesh_count,
	    mc.high_fidelity_mesh_count,
	    mc.fidelity_proportion_percent,
	    COALESCE(c.avg_mesh_complexity, 0) AS avg_mesh_complexity_ratio,
	    COALESCE(r.avg_resolution_mm, 0) AS avg_resolution_mm,
	    COALESCE(a.avg_geometric_accuracy_mm, 0) AS avg_geometric_accuracy_mm,
	    CASE
	        WHEN mc.fidelity_proportion_percent >= 90 AND
	             COALESCE(a.avg_geometric_accuracy_mm, 0) <= 1.0 AND
	             COALESCE(r.avg_resolution_mm, 0) <= 0.5 THEN 'Excellent'
	        WHEN mc.fidelity_proportion_percent >= 75 AND
	             COALESCE(a.avg_geometric_accuracy_mm, 0) <= 2.0 AND
