	  WHERE LOWER(pm.makertag) LIKE '%longi%'
	),
	current_output AS (
	  SELECT
	    pr.snapkey,
	    om.mtbfh * (pl.cap_mw * 1000) / NULLIF(COUNT(DISTINCT ppm.modlink)::real, 0) AS current_output
	  FROM longi_panels lp
	  JOIN plant_panel_model ppm ON lp.modlink = ppm.modlink
	  JOIN plants pl ON ppm.sitelink = pl.sitekey
	  JOIN plant_record pr ON pl.sitekey = pr.sitelist
	  JOIN operational_metrics om ON pr.snapkey = om.snapops
	  GROUP BY pr.snapkey, om.mtbfh, pl.cap_mw
	),
	starting_output AS (
	  SELECT
	    pr.snapkey,
	    om.mtbfh * (pl.cap_mw * 1000) / NULLIF(COUNT(DISTINCT ppm.modlink)::real, 0) AS starting_output
	  FROM longi_panels lp
	  JOIN plant_panel_model ppm ON lp.modlink = ppm.modlink
	  JOIN plants pl ON ppm.sitelink = pl.sitekey
	  JOIN plant_record pr ON pl.sitekey = pr.sitelist
	  JOIN operational_metrics om ON pr.snapkey = om.snapops
	  WHERE pr.snapts = (
	    SELECT MIN(snapts)
	    FROM plant_record pr2
	    JOIN plant_panel_model ppm2 ON ppm2.sitelink = pr2.sitelist
	    JOIN panel_models pm2 ON pm2.modkey = ppm2.modlink
	    WHERE pm2.makertag ILIKE '%longi%'
	  )
	  GROUP BY pr.snapkey, om.mtbfh, pl.cap_mw
	)
	SELECT AVG(COALESCE(CO.current_output / so.starting_output, 0)) AS mean_degradation_factor
	FROM current_output CO
	JOIN starting_output so ON CO.snapkey = so.snapkey
	WHERE CO.current_output > 0 AND so.starting_output > 0
