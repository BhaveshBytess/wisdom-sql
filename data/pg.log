	    ms.avg_resolution_mm,
	    ms.avg_geometric_accuracy_mm,
	    CASE
	      WHEN COALESCE(hf.high_fidelity_count, 0) > 0 THEN 'Has High-Fidelity Meshes'
	      WHEN ms.total_mesh_count > 0 THEN 'Standard Mesh Quality'
	      ELSE 'No Mesh Data'
	    END AS mesh_quality_category
	  FROM sites s
	  LEFT JOIN mesh_stats ms ON s.zoneregistry = ms.zoneref
	  LEFT JOIN high_fidelity hf ON ms.zoneref = hf.zoneref
	  ORDER BY
