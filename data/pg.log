	       CASE
	           WHEN art.ageYears > 500 THEN 5
	           WHEN art.ageYears BETWEEN 300 AND 500 THEN 3
	           ELSE 1
	       END AS priority_score,
	       CASE
	           WHEN (CASE
	                     WHEN art.conserve_status = 'Critical' THEN 10
	                     WHEN art.conserve_status = 'At Risk' THEN 8
	                     WHEN art.conserve_status = 'Stable' THEN 6
	                     ELSE 4
	                 END +
	                 COALESCE(rat.rating_profile->>'avg_rating', 0) * 2 +
	                 CASE
	                     WHEN art.ageYears > 500 THEN 5
	                     WHEN art.ageYears BETWEEN 300 AND 500 THEN 3
	                     ELSE 1
	                 END) >= 20 THEN 'Urgent Priority'
	           WHEN (CASE
	                     WHEN art.conserve_status = 'Critical' THEN 10
	                     WHEN art.conserve_status = 'At Risk' THEN 8
	                     WHEN art.conserve_status = 'Stable' THEN 6
	                     ELSE 4
	                 END +
	                 COALESCE(rat.rating_profile->>'avg_rating', 0) * 2 +
	                 CASE
	                     WHEN art.ageYears > 500 THEN 5
	                     WHEN art.ageYears BETWEEN 300 AND 500 THEN 3
	                     ELSE 1
	                 END) >= 15 THEN 'High Priority'
	           WHEN (CASE
	                     WHEN art.conserve_status = 'Critical' THEN 10
	                     WHEN art.conserve_status = 'At Risk' THEN 8
	                     WHEN art.conserve_status = 'Stable' THEN 6
	                     ELSE 4
	                 END +
