	    m.macd_line,
	    b.bollinger_width_pct,
	    CASE
	      WHEN r.rsi_14 > 70 THEN 'Overbought'
	      WHEN r.rsi_14 < 30 THEN 'Oversold'
	      WHEN r.rsi_14 BETWEEN 30 AND 70 THEN 'Neutral'
	      ELSE 'Unknown'
	    END AS rsi_signal,
	    CASE
	      WHEN m.macd_line > m.signal_line AND m.macd_line > 0 THEN 'Bullish'
	      WHEN m.macd_line < m.signal_line AND m.macd_line < 0 THEN 'Bearish'
	      ELSE 'Neutral'
	    END AS macd_signal,
	    CASE
	      WHEN b.bollinger_width_pct > 15 THEN 'High Volatility'
	      WHEN b.bollinger_width_pct BETWEEN 5 AND 15 THEN 'Moderate Volatility'
	      ELSE 'Low Volatility'
	    END AS volatility_signal
	  FROM rsi_result r
	  JOIN macd_calc m ON r.EXCH_SPOT = m.EXCH_SPOT AND r.TimeTrack = m.TimeTrack
	  JOIN bollinger_calc b ON r.EXCH_SPOT = b.EXCH_SPOT AND r.TimeTrack = b.TimeTrack
	)
	SELECT
	  EXCH_SPOT AS market,
	  TimeTrack AS timestamp,
	  ROUND(rsi_14, 2) AS rsi_14,
	  ROUND(macd_line, 6) AS macd_line,
	  ROUND(bollinger_width_pct, 2) AS bollinger_band_width_pct,
	  rsi_signal AS technical_meter_direction,
	  CASE
	    WHEN rsi_signal = 'Overbought' AND macd_signal = 'Bullish' AND volatility_signal = 'High Volatility' THEN 'Very Strong Bullish'
	    WHEN rsi_signal = 'Oversold' AND macd_signal = 'Bearish' AND volatility_signal = 'High Volatility' THEN 'Very Strong Bearish'
	    WHEN rsi_signal = 'Neutral' AND macd_signal = 'Bullish' AND volatility_signal = 'Moderate Volatility' THEN 'Strong Bullish'
	    WHEN rsi_signal = 'Neutral' AND macd_signal = 'Bearish' AND volatility_signal = 'Moderate Volatility' THEN 'Strong Bearish'
	    WHEN rsi_signal = 'Overbought' AND macd_signal = 'Neutral' AND volatility_signal = 'Moderate Volatility' THEN 'Moderate Bullish'
	    WHEN rsi_signal = 'Oversold' AND macd_signal = 'Neutral' AND volatility_signal = 'Moderate Volatility' THEN 'Moderate Bearish'
	    WHEN rsi_signal = 'Neutral' AND macd_signal = 'Neutral' AND volatility_signal = 'Low Volatility' THEN 'Neutral'
	    ELSE 'Weak Signal'
	  END AS calculated_strength
	FROM signal_strength
	ORDER BY TimeTrack DESC, EXCH_SPOT
