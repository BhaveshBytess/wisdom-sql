	    (price - AVG(price, 26) OVER (ORDER BY timestamp ROWS BETWEEN 25 PRECEDING AND CURRENT ROW)) AS macd_line,
	    AVG(
	      (price - AVG(price, 12) OVER (ORDER BY timestamp ROWS BETWEEN 11 PRECEDING AND CURRENT ROW)) -
	      (price - AVG(price, 26) OVER (ORDER BY timestamp ROWS BETWEEN 25 PRECEDING AND CURRENT ROW))
	    ) OVER (ORDER BY timestamp ROWS BETWEEN 25 PRECEDING AND CURRENT ROW) AS signal_line
	  FROM price_series
	),
	bollinger_calc AS (
	  SELECT
	    timestamp,
	    AVG(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) AS sma20,
	    STDDEV(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) AS stdev20,
	    price - AVG(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) -
	    2 * STDDEV(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) AS lower_band,
	    price - AVG(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) +
	    2 * STDDEV(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) AS upper_band,
	    (upper_band - lower_band) / AVG(price) OVER (ORDER BY timestamp ROWS BETWEEN 20 PRECEDING AND CURRENT ROW) * 100 AS bollinger_width
	  FROM price_series
	),
	last_values AS (
	  SELECT
	    r.rsi_value,
	    m.macd_line,
	    m.signal_line,
	    b.bollinger_width,
	    CASE
	      WHEN m.macd_line > m.signal_line AND r.rsi_value > 50 THEN 'Bullish'
	      WHEN m.macd_line < m.signal_line AND r.rsi_value < 50 THEN 'Bearish'
	      WHEN m.macd_line > m.signal_line AND r.rsi_value <= 50 THEN 'Weak Bullish'
	      WHEN m.macd_line < m.signal_line AND r.rsi_value >= 50 THEN 'Weak Bearish'
	      ELSE 'Neutral'
	    END AS meter_direction,
	    CASE
	      WHEN m.macd_line > m.signal_line AND r.rsi_value > 70 THEN 'Very Strong Buy'
	      WHEN m.macd_line > m.signal_line AND r.rsi_value > 50 THEN 'Strong Buy'
	      WHEN m.macd_line > m.signal_line AND r.rsi_value >= 30 THEN 'Moderate Buy'
	      WHEN m.macd_line < m.signal_line AND r.rsi_value < 30 THEN 'Very Strong Sell'
	      WHEN m.macd_line < m.signal_line AND r.rsi_value < 50 THEN 'Strong Sell'
	      WHEN m.macd_line < m.signal_line AND r.rsi_value <= 70 THEN 'Moderate Sell'
	      ELSE 'Neutral'
	    END AS strength
	  FROM rsi_calc r
	  JOIN macd_calc m ON r.timestamp = m.timestamp
	  JOIN bollinger_calc b ON m.timestamp = b.timestamp
	  ORDER BY r.timestamp DESC
	  LIMIT 1
	)
	SELECT rsi_value AS "RSI(14)", macd_line AS "MACD_Line", bollinger_width AS "Bollinger_Band_Width", meter_direction AS "Meter_Direction", strength AS "Calculated_Strength" FROM last_values
