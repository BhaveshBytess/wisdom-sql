2026-07-15 00:07:22.885 IST [24116] STATEMENT:  WITH smart_money_flow AS (
	    SELECT
	        md.exch_SPOT AS market_pair,
	        jsonb_array_elements_text(od.order_attributes->'smart_money_flow') AS flow_dominance,
	        jsonb_array_elements_text(od.order_attributes->'whale_activity') AS whale_activity,
	        jsonb_array_elements_text(od.order_attributes->'whale_activity_level') AS whale_activity_level
	    FROM orders od
	    JOIN marketdata md ON od.exchSpot = md.EXCH_SPOT
	    WHERE od.order_attributes ? 'smart_money_flow'
	      AND od.order_attributes ? 'whale_activity'
	      AND od.order_attributes ? 'whale_activity_level'
	),
	price_changes AS (
	    SELECT
	        md.exch_SPOT AS market_pair,
	        EXTRACT(EPOCH FROM (LEAD(md.TimeTrack) OVER (PARTITION BY md.exch_SPOT ORDER BY md.TimeTrack) - md.TimeTrack))/3600 AS hours_diff,
	        (LEAD(md.orderbook_metrics->>'markPrice') OVER (PARTITION BY md.exch_SPOT ORDER BY md.TimeTrack)::real -
	         md.orderbook_metrics->>'markPrice'::real) /
	        md.orderbook_metrics->>'markPrice'::real AS price_change_pct
	    FROM marketdata md
	    WHERE md.orderbook_metrics ? 'markPrice'
	),
	aggregated_metrics AS (
	    SELECT
	        smf.market_pair,
	        smf.flow_dominance,
	        smf.whale_activity,
	        smf.whale_activity_level,
	        AVG(CASE WHEN pc.hours_diff = 1 THEN pc.price_change_pct*100 END) AS avg_price_change_1h,
	        AVG(CASE WHEN pc.hours_diff = 4 THEN pc.price_change_pct*100 END) AS avg_price_change_4h,
	        AVG(CASE WHEN pc.hours_diff = 24 THEN pc.price_change_pct*100 END) AS avg_price_change_24h,
	        COUNT(CASE WHEN pc.price_change_pct > 0 AND smf.flow_dominance = 'Dominant' THEN 1 END)::real /
	        NULLIF(COUNT(CASE WHEN smf.flow_dominance = 'Dominant' THEN 1 END), 0) AS success_rate_dominant,
	        COUNT(CASE WHEN pc.price_change_pct > 0 AND smf.whale_activity = 'High' THEN 1 END)::real /
	        NULLIF(COUNT(CASE WHEN smf.whale_activity = 'High' THEN 1 END), 0) AS success_rate_high_whales,
	        COUNT(CASE WHEN pc.price_change_pct > 0 AND smf.whale_activity_level IN ('Whale', 'Mega Whale') THEN 1 END)::real /
	        NULLIF(COUNT(CASE WHEN smf.whale_activity_level IN ('Whale', 'Mega Whale') THEN 1 END), 0) AS success_rate_whale_level
	    FROM smart_money_flow smf
	    LEFT JOIN price_changes pc ON smf.market_pair = pc.market_pair
	    GROUP BY smf.market_pair, smf.flow_dominance, smf.whale_activity, smf.whale_activity_level
	)
	SELECT
	    flow_dominance,
	    whale_activity AS whale_activity_level,
	    market_pair,
	    ROUND(avg_price_change_1h, 4) AS avg_price_change_1h_pct,
	    ROUND(avg_price_change_4h, 4) AS avg_price_change_4h_pct,
	    ROUND(avg_price_change_24h, 4) AS avg_price_change_24h_pct,
	    ROUND(COALESCE(success_rate_dominant, success_rate_high_whales, success_rate_whale_level)*100, 2) AS success_rate_pct
	FROM aggregated_metrics
	ORDER BY success_rate_pct DESC NULLS LAST
