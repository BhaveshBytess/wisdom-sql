	        s.shiptok AS route,
	        COUNT(DISTINCT CASE WHEN m.temppts > p.tempmax OR m.temppts < p.tempmin THEN s.reckey END) AS excursion_count,
	        COUNT(*) AS total_shipments
	    FROM shipments s
	    LEFT JOIN shipsensorlink ssl ON ssl.shpnode = s.shiptok
	    LEFT JOIN monitoringdevices m ON m.mondevref = ssl.devnode
	    LEFT JOIN productbatches pb ON pb.batchtag = s.shiptok
	    LEFT JOIN products pr ON pr.prodcode = pb.prodlink
	    GROUP BY s.shiptok
	),
	route_risk_labels AS (
	    SELECT
	        s.shiptok AS route,
	        jsonb_extract_path_text(s.shipment_overview, 'risk_label') AS risk_label
	    FROM shipments s
	    GROUP BY s.shiptok, risk_label
	)
	SELECT
	    r.route,
	    r.risk_label,
	    COALESCE(rt.excursion_count, 0) AS excursion_count,
	    COALESCE(rt.total_shipments, 0) AS total_shipments,
	    CASE
	        WHEN r.risk_label = 'Low' AND COALESCE(rt.excursion_count, 0) > 0 THEN 'High Contradiction'
	        WHEN r.risk_label = 'Medium' AND COALESCE(rt.excursion_count, 0) >= 5 THEN 'High Contradiction'
	        WHEN r.risk_label = 'High' AND COALESCE(rt.excursion_count, 0) < 5 THEN 'Mismatch'
	        ELSE 'Potential Issue'
	    END AS problem_type
	FROM route_risk_labels r
	LEFT JOIN route_temp_data rt ON rt.route = r.route
	WHERE COALESCE(rt.excursion_count, 0) > 0
	ORDER BY rt.excursion_count DESC
	LIMIT 3
